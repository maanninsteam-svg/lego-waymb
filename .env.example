# Copiar este ficheiro para .env e preencher os valores reais.
# Em produção (Railway) configurar diretamente nas variáveis de ambiente.
# NUNCA commitar o ficheiro .env com valores reais.

# ── WayMB (Gateway de pagamento) ──────────────────────────────
WAYMB_CLIENT_ID=
WAYMB_SECRET=
WAYMB_EMAIL=

# ── Resend (Envio de emails) ───────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_NAME=LEGO World Cup 2026
RESEND_FROM_EMAIL=

# ── TikTok Events API ─────────────────────────────────────────
TIKTOK_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_TEST_CODE=

# ── UTMify ────────────────────────────────────────────────────
UTMIFY_API_TOKEN=
UTMIFY_PLATFORM=Tiktok

# ── Anthropic (IA de suporte) ─────────────────────────────────
ANTHROPIC_API_KEY=

# ── Webhook secret (Resend inbound emails) ────────────────────
WEBHOOK_SECRET=

# ── Admin Dashboard ───────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── Base de dados ─────────────────────────────────────────────
DB_PATH=db/lego_store.db
